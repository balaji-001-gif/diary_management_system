  },
  {
   "role": "Milk Collection Supervisor",
   "read": 1,
   "write": 1,
   "create": 1,
   "report": 1,
   "export": 1
  },
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1,
   "report": 1,
   "export": 1,
   "delete": 1
  }
 ]
