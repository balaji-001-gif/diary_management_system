 "naming_series_options": "BMC-.YYYY.MM.DD.-.##",
 "description": "Temperature readings and dispatch data for each BMC tank",
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "BMC-.YYYY.MM.DD.-.##"
  },
  {
   "fieldname": "bmc_id",
   "fieldtype": "Data",
   "label": "BMC ID",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "log_date",
   "fieldtype": "Date",
   "label": "Log Date",
   "reqd": 1,
   "default": "Today",
   "in_list_view": 1
  },
  {
   "fieldname": "sec_temp",
   "fieldtype": "Section Break",
   "label": "Temperature Readings"
  },
  {
   "fieldname": "morning_temp_c",
   "fieldtype": "Float",
   "label": "Morning Temp (\u00b0C)"
  },
  {
   "fieldname": "evening_temp_c",
   "fieldtype": "Float",
   "label": "Evening Temp (\u00b0C)"
  },
  {
   "fieldname": "col_vol",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "total_volume_litres",
   "fieldtype": "Float",
   "label": "Total Volume (Litres)"
  },
  {
   "fieldname": "dispatch_datetime",
   "fieldtype": "Datetime",
   "label": "Dispatch Date/Time"
  },
  {
   "fieldname": "transport_temp_c",
   "fieldtype": "Float",
   "label": "Transport Temp (\u00b0C)"
  }
 ],
