   "options": "REJ-.YYYY.-.####"
  },
  {
   "fieldname": "collection_entry",
   "fieldtype": "Link",
   "label": "Collection Entry",
   "options": "Milk Collection Entry",
   "in_list_view": 1
  },
  {
   "fieldname": "farmer",
