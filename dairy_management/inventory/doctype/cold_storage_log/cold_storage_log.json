{
 "doctype": "DocType",
 "name": "Cold Storage Log",
 "module": "Inventory",
 "custom": 0,
 "is_submittable": 0,
 "autoname": "naming_series:",
 "naming_series_options": "CSL-.YYYY.MM.DD.-.##",
 "description": "Temperature readings for cold storage warehouses",
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "CSL-.YYYY.MM.DD.-.##"
  },
  {
   "fieldname": "warehouse",
   "fieldtype": "Link",
   "label": "Warehouse",
   "options": "Warehouse",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "log_date",
   "fieldtype": "Date",
   "label": "Date",
   "reqd": 1,
   "default": "Today",
   "in_list_view": 1
  },
  {
   "fieldname": "sec_readings",
   "fieldtype": "Section Break",
   "label": "Readings"
  },
  {
   "fieldname": "readings",
   "fieldtype": "Table",
   "label": "Temperature Readings",
   "options": "Temperature Reading"
  },
  {
   "fieldname": "sec_summary",
   "fieldtype": "Section Break",
   "label": "Summary"
  },
  {
   "fieldname": "min_temp_recorded_c",
   "fieldtype": "Float",
   "label": "Min Temp Recorded (\u00b0C)",
   "read_only": 1
  },
  {
   "fieldname": "max_temp_recorded_c",
   "fieldtype": "Float",
   "label": "Max Temp Recorded (\u00b0C)",
   "read_only": 1
  },
  {
   "fieldname": "col_breach",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "temperature_breach",
   "fieldtype": "Check",
   "label": "Temperature Breach",
   "read_only": 1
  },
  {
   "fieldname": "breach_notified_to",
   "fieldtype": "Data",
   "label": "Breach Notified To"
  }
 ],
 "permissions": [
  {
   "role": "Dairy Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "report": 1,
   "export": 1
  },
  {
   "role": "Milk Collection Supervisor",
   "read": 1,
   "write": 1,
   "create": 1,
   "report": 1,
   "export": 1
  },
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1,
   "report": 1,
   "export": 1,
   "delete": 1
  }
 ]
}