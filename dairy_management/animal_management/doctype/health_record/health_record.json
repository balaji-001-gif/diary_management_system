{
 "doctype": "DocType",
 "name": "Health Record",
 "module": "Animal Management",
 "custom": 0,
 "is_submittable": 1,
 "naming_rule": "Expression",
 "autoname": "naming_series:",
 "naming_series_options": "HR-.YYYY.-.####",
 "description": "Health event log — vaccination, treatment, deworming, checkup",
 "fields": [
  {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "HR-.YYYY.-.####"},
  {"fieldname": "animal", "fieldtype": "Link", "label": "Animal", "options": "Animal", "reqd": 1, "in_list_view": 1},
  {"fieldname": "date", "fieldtype": "Date", "label": "Date", "reqd": 1, "default": "Today", "in_list_view": 1},
  {"fieldname": "col_event", "fieldtype": "Column Break"},
  {"fieldname": "event_type", "fieldtype": "Select", "label": "Event Type", "options": "Vaccination\nTreatment\nDeworming\nCheckup", "reqd": 1, "in_list_view": 1},
  {"fieldname": "disease_condition", "fieldtype": "Data", "label": "Disease / Condition"},
  {"fieldname": "sec_treatment", "fieldtype": "Section Break", "label": "Treatment Details"},
  {"fieldname": "medicine", "fieldtype": "Data", "label": "Medicine / Vaccine"},
  {"fieldname": "dose", "fieldtype": "Data", "label": "Dose & Route"},
  {"fieldname": "col_vet", "fieldtype": "Column Break"},
  {"fieldname": "vet_name", "fieldtype": "Data", "label": "Veterinarian"},
  {"fieldname": "cost", "fieldtype": "Currency", "label": "Treatment Cost"},
  {"fieldname": "next_due_date", "fieldtype": "Date", "label": "Next Due Date"}
 ],
 "permissions": [
  {"role": "Dairy Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
  {"role": "Route Agent", "read": 1, "write": 1, "create": 1}
 ]
}
