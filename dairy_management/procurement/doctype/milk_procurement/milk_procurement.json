  {"fieldname": "supplier", "fieldtype": "Link", "label": "Supplier", "options": "Supplier", "reqd": 1, "in_list_view": 1},
  {"fieldname": "receipt_date", "fieldtype": "Date", "label": "Receipt Date", "reqd": 1, "default": "Today", "in_list_view": 1},
  {"fieldname": "vehicle_number", "fieldtype": "Data", "label": "Vehicle Number"},
  {"fieldname": "sec_qty", "fieldtype": "Section Break", "label": "Quantity & Quality"},
  {"fieldname": "quantity_litres", "fieldtype": "Float", "label": "Quantity (Litres)", "reqd": 1},
  {"fieldname": "avg_fat_percentage", "fieldtype": "Float", "label": "Avg Fat %"},
  {"fieldname": "col_snf", "fieldtype": "Column Break"},
  {"fieldname": "avg_snf_percentage", "fieldtype": "Float", "label": "Avg SNF %"},
  {"fieldname": "agreed_rate_per_litre", "fieldtype": "Currency", "label": "Agreed Rate (per litre)", "reqd": 1},
  {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Amount", "read_only": 1},
  {"fieldname": "purchase_receipt", "fieldtype": "Link", "label": "Purchase Receipt", "options": "Purchase Receipt", "read_only": 1}
 ],
 "permissions": [
  {"role": "Dairy Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "amend": 1},
  {"role": "Milk Collection Supervisor", "read": 1, "write": 1, "create": 1}
 ]
}
